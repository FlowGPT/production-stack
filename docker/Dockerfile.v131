# v1.3.1 router image: overlays all changed-since-v1.2 router files onto the
# released v1.2 image (pure-Python overlay, no rebuild; same approach as
# Dockerfile.v13). Adds the redis-backed shared affinity store + soft-dependency
# on top of the v1.3 load_balanced_affinity router. Build context = repo root.
#
# Layered on top of v1.2 (redis/xxhash already present in v1.2):
#   - service_discovery.py                (K8s stale-engine reconcile)
#   - services/request_service/request.py (non-ASCII header fwd + active-req gauge)
#   - routers/routing_logic.py            (load_balanced_affinity P2C + affinity store)
#   - routers/affinity_store.py           (NEW: memory/redis stores, soft dep)
#   - routers/metrics_router.py           (window-metrics + multiproc aggregation)
#   - services/metrics_service/__init__.py(new metrics + capacity gauges)
#   - parsers/parser.py, app.py           (CLI wiring + event-loop-lag monitor)
FROM ssadds/production-stack-router:v1.2

ARG PKG=/usr/local/lib/python3.12/site-packages/vllm_router

COPY src/vllm_router/service_discovery.py ${PKG}/service_discovery.py
COPY src/vllm_router/services/request_service/request.py ${PKG}/services/request_service/request.py
COPY src/vllm_router/routers/routing_logic.py ${PKG}/routers/routing_logic.py
COPY src/vllm_router/routers/affinity_store.py ${PKG}/routers/affinity_store.py
COPY src/vllm_router/routers/metrics_router.py ${PKG}/routers/metrics_router.py
COPY src/vllm_router/services/metrics_service/__init__.py ${PKG}/services/metrics_service/__init__.py
COPY src/vllm_router/parsers/parser.py ${PKG}/parsers/parser.py
COPY src/vllm_router/app.py ${PKG}/app.py
